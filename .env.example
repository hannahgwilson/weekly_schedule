# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Google Calendar IDs (found in GCal Settings > calendar > "Integrate calendar")
GCAL_PERSONAL_ID=hannah@gmail.com
GCAL_FAMILY_ID=family-calendar-id@group.calendar.google.com
