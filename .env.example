# Google OAuth credentials file path (download from Google Cloud Console)
GOOGLE_CREDENTIALS_PATH=credentials.json

# Open Brain MCP (optional — enables auto-pull of notes from your Open Brain)
# URL format: https://YOUR_PROJECT_REF.supabase.co/functions/v1/open-brain-mcp?key=YOUR_ACCESS_KEY
OPEN_BRAIN_MCP_URL=
